SECRET_KEY=change-this-secret

# Primary DB connection (Supabase/Postgres preferred)
# Example: postgresql://user:password@db-host:5432/dbname
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>

# Alternatively explicit Supabase envs
SUPABASE_DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>
SUPABASE_ANON_KEY=<supabase_anon>
SUPABASE_SERVICE_ROLE_KEY=<supabase_service_role>

# Cloudinary (either CLOUDINARY_URL or individual keys)
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

# Flask settings
FLASK_ENV=development
DEBUG=True